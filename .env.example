# Telegram Bot Credentials (Server-side)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram Bot Credentials (Client-side / For APK)
# IMPORTANT: Put your keys here if you want to use the APK without a backend server.
# These must start with VITE_ to be accessible in the Android app.
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=

# Real-time Advertisements & Sponsors Source
# You can connect a custom unblocked public JSON / Gist URL here to sync sponsors dynamically
ADS_SOURCE_URL=

# Secure Admin Passcode for Ads Management (Server-side environment variable)
# Set this to a custom value to protect your live ads setup from unauthorized updates.
ADS_ADMIN_PASSCODE=gasino_admin
